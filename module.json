  "flags": {
    "pf2e-keepers-of-the-grave-world": {
      "pf2e-homebrew": {
		"baseArmors": {
		  "grave-mantle": "Grave Mantle",
		  "skitterhide": "Skitterhide"
		},
		"baseWeapons": {
		  "corpse-fleet-dueling-sword": "Corpse Fleet Dueling Sword",
		  "void-staff": "Void Staff",
		  "bone-pistol": "Bone Pistol",
		  "void-rifle": "Void Rifle"
		},
        "equipmentTraits": {
          "necrotech": {
            "label": "Necrotech",
            "description": "Necrografts are a combination of necromancy and cybernetics made using the tissue of undead. Necrotech augmentation are magical, but they can’t be dispelled unless the effect or attack specifies that it attacks augmentations. A creature with at least one necrotech augment installed gains the undead trait and is damaged by vitality damage (though they are still affected by vitality healing as normal)."
          },
		  "elebrian": "Elebrian"
        },
        "weaponTraits": {
          "elebrian": "Elebrian",
          "necrotech": {
            "label": "Necrotech",
            "description": "Necrografts are a combination of necromancy and cybernetics made using the tissue of undead. Necrotech augmentation are magical, but they can’t be dispelled unless the effect or attack specifies that it attacks augmentations. A creature with at least one necrotech augment installed gains the undead trait and is damaged by vitality damage (though they are still affected by vitality healing as normal)."
          }
        }
      }
    }
  },
